{
  "name": "@hanzogui/core-test",
  "version": "3.0.0",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Nate Wienert"
  },
  "type": "module",
  "module": "dist/esm",
  "scripts": {
    "test:run": "vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts",
    "test:web": "HANZO_GUI_TARGET=web vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts *.web.test.tsx",
    "test:ios": "TEST_NATIVE_PLATFORM=ios HANZO_GUI_TARGET=native vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts *.ios.test.tsx",
    "test:native": "HANZO_GUI_TARGET=native vitest --run --config ../../packages/vite-plugin-internal/src/vite.config.ts *.native.test.tsx",
    "test": "bun run test:native && bun run test:web && bun run test:ios",
    "test:update": "bun run test:native --update && bun run test:web --update"
  },
  "devDependencies": {
    "@hanzogui/core": "3.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/react-native": "^12.9.0",
    "csstype": "^3.0.10",
    "react": ">=19",
    "typescript": "~5.9.2",
    "vitest": "4.0.4"
  },
  "peerDependencies": {
    "react": ">=19"
  }
}
