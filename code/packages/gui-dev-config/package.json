{
  "name": "@hanzogui/dev-config",
  "version": "3.0.6",
  "source": "src/index.ts",
  "files": [
    "src",
    "types",
    "dist",
    "motion.cjs"
  ],
  "type": "module",
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./motion": {
      "types": "./src/animations.motion.ts",
      "browser": "./dist/esm/animations.motion.mjs",
      "module": "./dist/esm/animations.motion.mjs",
      "import": "./dist/esm/animations.motion.mjs",
      "require": "./dist/cjs/animations.motion.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "hanzo-gui-build --skip-types --skip-native",
    "watch": "hanzo-gui-build --skip-types --skip-native --watch",
    "clean": "hanzo-gui-build clean",
    "clean:build": "hanzo-gui-build clean:build"
  },
  "dependencies": {
    "@hanzogui/animations-css": "3.0.6",
    "@hanzogui/animations-moti": "3.0.6",
    "@hanzogui/animations-motion": "3.0.6",
    "@hanzogui/animations-reanimated": "3.0.6",
    "@hanzogui/colors": "3.0.6",
    "@hanzogui/config": "3.0.6",
    "@hanzogui/core": "3.0.6",
    "@hanzogui/font-cherry-bomb": "3.0.6",
    "@hanzogui/font-inter": "3.0.6",
    "@hanzogui/font-silkscreen": "3.0.6",
    "@hanzogui/shorthands": "3.0.6",
    "@hanzogui/theme-builder": "3.0.6",
    "@hanzogui/themes": "3.0.6",
    "color2k": "^2.0.2"
  },
  "devDependencies": {
    "@hanzogui/build": "3.0.6",
    "react": ">=19"
  },
  "peerDependencies": {
    "react": ">=19"
  }
}
