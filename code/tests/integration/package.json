    "@hanzogui/shorthands": "3.0.6",
    "@hanzogui/react-native-web-lite": "3.0.6",
    "@hanzo/gui": "4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@hanzogui/vite-plugin": "3.0.6",
    "async-retry": "1.3.1",
    "react-dom": "*",
    "vite": "^8.0.0",
    "wait-port": "^0.3.0"
