{
  "name": "@hanzogui/admin",
  "version": "0.1.0",
  "description": "Composable admin shell + primitives + data hooks for Hanzo admin surfaces. Pure Tamagui via the hanzogui umbrella. One way to build admin UI across tasks, kms, commerce, console.",
  "type": "module",
  "source": "src/index.ts",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./shell": "./src/shell/index.ts",
    "./primitives": "./src/primitives/index.ts",
    "./data": "./src/data/index.ts",
    "./patterns": "./src/patterns/index.ts"
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "hanzogui": ">=102.0.0-rc.41-hanzoai.1",
    "@hanzogui/lucide-icons-2": ">=7.0.0",
    "react": ">=19",
    "react-router-dom": ">=7"
  },
  "publishConfig": {
    "access": "public"
  }
}
