{
  "name": "hanzo-gui-build-test-simple-tpackage",
  "version": "2.0.0-rc.0-1769885482630",
  "main": "dist/cjs",
  "module": "dist/esm",
  "module:jsx": "dist/jsx",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "build": "node ../../../hanzo-gui-build.js",
    "build:bundle": "node ../../../hanzo-gui-build.js --bundle",
    "build:skip-mjs": "node ../../../hanzo-gui-build.js --skip-mjs",
    "build:skip-sourcemaps": "node ../../../hanzo-gui-build.js --skip-sourcemaps",
    "build:declaration-root": "node ../../../hanzo-gui-build.js --declaration-root",
    "build:ignore-base-url": "node ../../../hanzo-gui-build.js --ignore-base-url",
    "build:watch": "node ../../../hanzo-gui-build.js --watch",
    "build:minify": "MINIFY=true node ../../../hanzo-gui-build.js",
    "build:target-web": "HANZO_GUI_TARGET=web node ../../../hanzo-gui-build.js",
    "build:target-native": "HANZO_GUI_TARGET=native node ../../../hanzo-gui-build.js"
  },
  "devDependencies": {
    "@hanzo/gui-build": "workspace:*",
    "typescript": "~5.9.2"
  }
}
