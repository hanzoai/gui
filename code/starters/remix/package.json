{
  "name": "@hanzogui/remix-starter",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build:web": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "prod": "bun run build:web && bun run start",
    "upgrade:gui": "bunx npm-check-updates -u '*gui*' '@hanzogui/*' && bun install"
  },
  "dependencies": {
    "@remix-run/node": "^2.12.1",
    "@remix-run/react": "^2.12.1",
    "@remix-run/serve": "^2.12.1",
    "@hanzogui/config": "3.0.6",
    "isbot": "^4.1.0",
    "react": ">=19",
    "react-dom": "*",
    "@hanzo/gui": "4.3.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.12.1",
    "@hanzogui/vite-plugin": "3.0.6",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "typescript": "~5.9.2",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.9",
  "version": "4.3.1"
}
