{
  "name": "@hanzogui/demos",
  "version": "3.0.0",
  "source": "demos/src/index.tsx",
  "files": [
    "src",
    "types",
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./src",
  "exports": {
    "./package.json": "./package.json",
    "./photo/*": "./public/*.jpg",
    ".": {
      "types": "./src/index.tsx",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./demo/*": {
      "types": "./types/*.d.ts",
      "react-native": "./dist/esm/*.native.js",
      "browser": "./dist/esm/*.mjs",
      "module": "./dist/esm/*.mjs",
      "import": "./dist/esm/*.mjs",
      "require": "./dist/cjs/*.cjs",
      "default": "./dist/esm/*.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "hanzo-gui-build --skip-types",
    "watch": "hanzo-gui-build --skip-types --watch",
    "clean": "hanzo-gui-build clean",
    "clean:build": "hanzo-gui-build clean:build"
  },
  "dependencies": {
    "@hanzogui/colors": "3.0.0",
    "@hanzogui/config": "3.0.0",
    "@hanzogui/core": "3.0.0",
    "@hanzogui/get-button-sized": "3.0.0",
    "@hanzogui/logo": "3.0.0",
    "@hanzogui/lucide-icons-2": "3.0.0",
    "@hanzogui/dev-config": "3.0.0",
    "@hanzogui/theme": "3.0.0",
    "@hanzo/gui": "workspace:*"
  },
  "devDependencies": {
    "@hanzogui/build": "3.0.0",
    "react": ">=19",
    "react-native": "0.83.2"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": "*"
  }
}
