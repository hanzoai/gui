{
  "name": "@hanzogui/sheet",
  "version": "102.0.0-rc.41-hanzoai.1",
  "license": "MIT",
  "source": "src/index.ts",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "typesVersions": {
    "*": {
      "setup-gesture-handler": [
        "./types/setupGestureHandler.d.ts"
      ]
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./controller": {
      "types": "./types/controller.d.ts",
      "react-native": "./dist/esm/controller.native.js",
      "browser": "./dist/esm/controller.mjs",
      "module": "./dist/esm/controller.mjs",
      "import": "./dist/esm/controller.mjs",
      "require": "./dist/cjs/controller.cjs",
      "default": "./dist/cjs/controller.native.js"
    },
    "./setup-gesture-handler": {
      "types": "./types/setupGestureHandler.d.ts",
      "react-native": "./dist/esm/setupGestureHandler.native.js",
      "browser": "./dist/esm/setupGestureHandler.mjs",
      "module": "./dist/esm/setupGestureHandler.mjs",
      "import": "./dist/esm/setupGestureHandler.mjs",
      "require": "./dist/cjs/setupGestureHandler.cjs",
      "default": "./dist/esm/setupGestureHandler.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "hanzogui-build",
    "watch": "hanzogui-build --watch",
    "clean": "hanzogui-build clean"
  },
  "dependencies": {
    "@hanzogui/adapt": "workspace:*",
    "@hanzogui/animate-presence": "workspace:*",
    "@hanzogui/animations-react-native": "workspace:*",
    "@hanzogui/compose-refs": "workspace:*",
    "@hanzogui/constants": "workspace:*",
    "@hanzogui/core": "workspace:*",
    "@hanzogui/create-context": "workspace:*",
    "@hanzogui/helpers": "workspace:*",
    "@hanzogui/native": "workspace:*",
    "@hanzogui/portal": "workspace:*",
    "@hanzogui/remove-scroll": "workspace:*",
    "@hanzogui/scroll-view": "workspace:*",
    "@hanzogui/stacks": "workspace:*",
    "@hanzogui/use-constant": "workspace:*",
    "@hanzogui/use-controllable-state": "workspace:*",
    "@hanzogui/use-did-finish-ssr": "workspace:*",
    "@hanzogui/use-keyboard-visible": "workspace:*",
    "@hanzogui/z-index-stack": "workspace:*"
  },
  "devDependencies": {
    "@hanzogui/build": "workspace:*",
    "react": ">=19",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": "*",
    "react-native-gesture-handler": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-gesture-handler": {
      "optional": true
    }
  },
  "module:jsx": "dist/jsx",
  "removeSideEffects": true,
  "files": [
    "dist",
    "src",
    "types",
    "*.cjs",
    "*.mjs",
    "*.css",
    "README.md"
  ]
}
