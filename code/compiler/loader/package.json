  "files": [
    "src",
    "types",
    "dist"
  ],
  "type": "module",
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/cjs/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "hanzo-gui-build --skip-native",
    "watch": "hanzo-gui-build --skip-native --watch",
    "clean": "hanzo-gui-build clean",
    "clean:build": "hanzo-gui-build clean:build"
  },
  "dependencies": {
    "@hanzogui/cli-color": "3.0.6",
    "@hanzogui/core": "3.0.6",
    "@hanzogui/static": "3.0.6",
    "@hanzogui/static-worker": "3.0.6",
    "@hanzogui/types": "3.0.6",
    "@hanzogui/web": "3.0.6",
    "esbuild-loader": "^4.2.2",
    "esm-resolve": "^1.0.8",
    "fs-extra": "^11.2.0",
    "loader-utils": "^3.2.1"
  },
  "devDependencies": {
    "@hanzogui/build": "3.0.6",
    "prettyjson": "^1.2.5",
    "webpack": "^5.88.2"
  }
