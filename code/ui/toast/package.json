{
  "name": "@hanzogui/toast",
  "version": "2.0.0-rc.41-hanzoai.5",
  "source": "src/index.ts",
  "files": [
    "src",
    "types",
    "dist",
    "v2"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./v2": {
      "types": "./types/v2.d.ts",
      "react-native": "./dist/esm/v2.native.js",
      "browser": "./dist/esm/v2.mjs",
      "module": "./dist/esm/v2.mjs",
      "import": "./dist/esm/v2.mjs",
      "require": "./dist/cjs/v2.cjs",
      "default": "./dist/esm/v2.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "hanzogui-build",
    "watch": "hanzogui-build --watch",
    "clean": "hanzogui-build clean",
    "clean:build": "hanzogui-build clean:build"
  },
  "dependencies": {
    "@hanzogui/animate-presence": "workspace:*",
    "@hanzogui/collection": "workspace:*",
    "@hanzogui/compose-refs": "workspace:*",
    "@hanzogui/constants": "workspace:*",
    "@hanzogui/core": "workspace:*",
    "@hanzogui/create-context": "workspace:*",
    "@hanzogui/dismissable": "workspace:*",
    "@hanzogui/helpers": "workspace:*",
    "@hanzogui/native": "workspace:*",
    "@hanzogui/polyfill-dev": "workspace:*",
    "@hanzogui/portal": "workspace:*",
    "@hanzogui/stacks": "workspace:*",
    "@hanzogui/start-transition": "workspace:*",
    "@hanzogui/text": "workspace:*",
    "@hanzogui/use-controllable-state": "workspace:*",
    "@hanzogui/visually-hidden": "workspace:*"
  },
  "devDependencies": {
    "@hanzogui/build": "workspace:*",
    "react": ">=19",
    "react-native": "0.83.2"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": "*"
  },
  "module:jsx": "dist/jsx",
  "typesVersions": {
    "*": {
      "v2": [
        "./types/v2.d.ts"
      ]
    }
  }
