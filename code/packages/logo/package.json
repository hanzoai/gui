{
  "name": "@hanzogui/logo",
  "version": "2.0.4",
  "source": "src/index.tsx",
  "files": [
    "src",
    "types",
    "dist",
    "*.cjs",
    "icon"
  ],
  "type": "module",
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./icon": {
      "types": "./types/LogoIcon.d.ts",
      "react-native": "./dist/esm/LogoIcon.native.js",
      "browser": "./dist/esm/LogoIcon.mjs",
      "module": "./dist/esm/LogoIcon.mjs",
      "import": "./dist/esm/LogoIcon.mjs",
      "require": "./dist/cjs/LogoIcon.cjs",
      "default": "./dist/cjs/LogoIcon.native.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "hanzo-gui-build",
    "watch": "hanzo-gui-build --watch",
    "clean": "hanzo-gui-build clean",
    "clean:build": "hanzo-gui-build clean:build"
  },
  "dependencies": {
    "@hanzogui/use-element-layout": "2.0.4",
    "@hanzogui/web": "2.0.4",
    "@hanzo/gui": "2.0.0"
  },
  "devDependencies": {
    "@hanzogui/build": "2.0.4",
    "react": ">=19"
  },
  "peerDependencies": {
    "react": ">=19"
  }
}
